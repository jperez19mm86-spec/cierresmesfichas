# ── Venta de Fichas — variables de entorno ──
# Copiá este archivo a .env para correr local. En Railway, cargá estas variables en el panel.
# (NO subas el .env real a GitHub — ya está en .gitignore.)

# Puerto. En local 4600; en Railway lo asigna Railway solo (no hace falta tocar).
PORT=4600

# ── LOGIN del panel (¡obligatorio en producción!) ──
# Usuario y contraseña para entrar al panel de admin.
PANEL_USER=admin
PANEL_PASSWORD=cambia-esta-clave

# Clave secreta para firmar la cookie de sesión. Poné un valor largo y al azar.
# Generá uno con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=pega-aca-un-secreto-largo-al-azar

# Clave maestra para CIFRAR las contraseñas de los Sistemas (casino) en la base.
# ⚠️ NO la cambies una vez que cargaste sistemas, o vas a tener que volver a poner sus contraseñas.
# Generá una con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRED_KEY=pega-aca-otro-secreto-largo-al-azar

# ── Base de datos ──
# Ruta del archivo SQLite. Por defecto data/store.sqlite (relativo al proyecto).
# En Railway: montá un VOLUME en /app/data y NO hace falta tocar esto (queda en /app/data/store.sqlite).
# DB_PATH=/app/data/store.sqlite

# ── Telegram (opcional) ──
# El token del bot también se puede cargar desde el panel (Clientes → Avisos por Telegram).
# TELEGRAM_BOT_TOKEN=123456789:ABC...

# ── Google Sheets (opcional) ──
# Registra cada carga/rechazo en una Google Sheet (una pestaña por mes, con filtro por cliente).
# 1) En tu Sheet: Extensiones → Apps Script → pegá el script → Implementar como Aplicación web.
# 2) Pegá acá la URL /exec que te da Google.
# SHEET_WEBHOOK_URL=https://script.google.com/macros/s/AKfy.../exec
# (Opcional) Secreto compartido: si lo ponés acá Y en el Apps Script, valida que el POST venga de acá.
# SHEET_SECRET=
# (Opcional) Zona horaria para las fechas de la Sheet (default America/Argentina/Buenos_Aires).
# SHEET_TZ=America/Argentina/Buenos_Aires
